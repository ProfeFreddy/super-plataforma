{
  "functions": [
    {
      "codebase": "default",
      "source": "functions"
    },
    {
      "source": "gincana",
      "codebase": "gincana",
      "disallowLegacyRuntimeConfig": true,
      "ignore": ["node_modules",".git","firebase-debug.log","firebase-debug.*.log","*.local"]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json","**/..*","**/node_modules/**"],
    "cleanUrls": false,
    "headers": [
      {"source":"/juego/Build/**.js","headers":[{"key":"Content-Type","value":"application/javascript"}]},
      {"source":"/juego/Build/**.framework.js.gz","headers":[{"key":"Content-Type","value":"application/javascript"},{"key":"Content-Encoding","value":"gzip"}]},
      {"source":"/juego/Build/**.wasm.gz","headers":[{"key":"Content-Type","value":"application/wasm"},{"key":"Content-Encoding","value":"gzip"}]},
      {"source":"/juego/Build/**.data.gz","headers":[{"key":"Content-Encoding","value":"gzip"}]}
    ],
    "redirects": [
      {"source":"/","destination":"/juego/index.html","type":302}
    ],
    "rewrites": [
      {"source":"/api/**","function":"app"},
      {"source":"/juego","destination":"/juego/index.html"},
      {"source":"/juego/**","destination":"/juego/index.html"},
      {"source":"/planes.html","destination":"/planes.html"},
      {"source":"/pago-exitoso.html","destination":"/pago-exitoso.html"},
      {"source":"/profe.html","destination":"/profe.html"},
      {"source":"**","destination":"/index.html","type":200}
    ]
  },
  "emulators": {
    "functions": {"port": 5001},
    "hosting": {"port": 5174},
    "ui": {"enabled": true}
  }
}